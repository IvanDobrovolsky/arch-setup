# arch-setup: custom bash config
# Source this from ~/.bashrc

# ── Functions ────────────────────────────────────────────────────────

# Copy file contents or piped input to clipboard
copy() {
  if [ -t 0 ] && [ -n "${1:-}" ]; then
    wl-copy < "$1"
  else
    wl-copy
  fi
}

# Open tmux working directory layout: nvim, claude, lazygit, terminal
twd() {
  local dir
  dir="$(cd "${1:-.}" && pwd)"
  local session_name
  session_name="$(basename "$dir" | tr '.:' '--')"

  # Start tmux if not already in it
  if [[ -z "${TMUX:-}" ]]; then
    if tmux has-session -t "$session_name" 2>/dev/null; then
      tmux attach-session -t "$session_name"
    else
      tmux new-session -d -s "$session_name" -c "$dir"
      tmux send-keys -t "$session_name" "twd '$dir'" C-m
      tmux attach-session -t "$session_name"
    fi
    return
  fi

  local editor_pane="$TMUX_PANE"

  tmux rename-window -t "$editor_pane" "$(basename "$dir")"

  # 1. Split left/right: editor (65%) | claude (35%)
  local top_right
  top_right=$(tmux split-window -h -l 35% -t "$editor_pane" -c "$dir" -P -F '#{pane_id}')

  # 2. Split claude pane top/bottom: claude (75%) | terminal (25%)
  tmux split-window -v -l 25% -t "$top_right" -c "$dir"

  # 3. Split editor pane top/bottom: nvim (75%) | lazygit (25%)
  local bottom_left
  bottom_left=$(tmux split-window -v -l 25% -t "$editor_pane" -c "$dir" -P -F '#{pane_id}')

  # Start apps
  tmux send-keys -t "$editor_pane" "cd '$dir' && $EDITOR ." C-m
  tmux send-keys -t "$top_right" "cd '$dir' && cx" C-m
  tmux send-keys -t "$bottom_left" "cd '$dir' && lazygit" C-m

  # Focus nvim
  tmux select-pane -t "$editor_pane"
}
